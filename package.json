{
  "name": "vue-training",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": "26",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "_examples/*",
    "_exercises/*",
    "_solutions/*"
  ],
  "scripts": {
    "test-all": "pnpm -r run --if-present test:unit --run --passWithNoTests",
    "build-all": "pnpm -r exec vite build",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm exec playwright install",
    "start:welcome": "cd _examples/Welcome && pnpm run dev",
    "start:1": "cd _exercises/01-Advanced-Reactivity && pnpm run dev",
    "start:2": "cd _exercises/02-Advanced-Routing && pnpm run dev",
    "start:3": "cd _exercises/03-E2E-Testing && pnpm run test:e2e:ui",
    "start:4": "cd _exercises/04-Advanced-Pinia-LocalStorage && pnpm run dev",
    "start:5": "cd _exercises/05-ClientApiMocking && pnpm run dev",
    "start:6": "cd _exercises/06-Prove-Yourself && pnpm run dev",
    "solution:1": "cd _solutions/01-Advanced-Reactivity && pnpm run dev",
    "solution:2": "cd _solutions/02-Advanced-Routing && pnpm run dev",
    "solution:3": "cd _solutions/03-E2E-Testing && pnpm run test:e2e:ui",
    "solution:4": "cd _solutions/04-Advanced-Pinia-LocalStorage && pnpm run dev",
    "solution:5": "cd _solutions/05-ClientApiMocking && pnpm run dev",
    "solution:6": "cd _solutions/06-Prove-Yourself && pnpm run dev",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource-variable/source-code-pro": "^5.2.7",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@sit-onyx/headless": "0.7.0",
    "@sit-onyx/icons": "1.6.0",
    "@vueuse/core": "^13.9.0",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "sit-onyx": "1.6.0",
    "vue": "^3.5.38",
    "vue-component-type-helpers": "^3.3.5",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@eslint/js": "9.36.0",
    "@hey-api/openapi-ts": "^0.99.0",
    "@import-meta-env/cli": "~0.7.4",
    "@import-meta-env/typescript": "~0.4.1",
    "@import-meta-env/unplugin": "~0.6.3",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@pinia/testing": "^1.0.3",
    "@playwright/experimental-ct-vue": "~1.61.1",
    "@playwright/test": "~1.61.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.19.21",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/compiler-dom": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.8.1",
    "@yao-pkg/pkg": "^6.20.0",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "msw": "^2.14.6",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "sass-embedded": "^1.100.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.4.3",
    "vite-plugin-run": "~0.6.1",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vitest": "^3.2.6",
    "vitest-mock-extended": "^3.1.1",
    "vitest-sonar-reporter": "^2.0.4",
    "vue-eslint-parser": "^10.4.1",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.12",
    "z-vue-scan": "^0.0.35"
  }
}
