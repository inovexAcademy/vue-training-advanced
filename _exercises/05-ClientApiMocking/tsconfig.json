{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./tests/*"]
    },
    "resolveJsonModule": true,
    "target": "esnext",
    "noUncheckedIndexedAccess": true,
    "ignoreDeprecations": "5.0"
  },
  "extends": "../../tsconfig.json",
  "include": [
    "./src/types/env.d.ts",
    "./src/**/*",
    "./src/**/*.vue",
    "./package.json",
    "./tests/**/*",
    "openapi-ts.config.ts"
  ]
}
